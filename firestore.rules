rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: orders
    // Fields: orderNo, customerName, materialGrade, totalQuantity, deliveryDate, status, createdAt
    //
    // Collection: batches
    // Fields: batchNo, materialType, receivedDate
    //
    // Collection: bandSawEntries
    // Fields: masterBatchNo, subBundleNo, cutLength, pcsCut, weight, endCutWeight, date, status
    //
    // Collection: inspections
    // Fields: bundleId, pcsNo, od, thickness, length, surface, remarks
    //
    // Collection: productionReports
    // Fields: date, shift, productionKg, waterTankers, lpgKg, electricityUnits, etc.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "prashantbagriya7877@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidBatch(data) {
      return data.batchNo is string && data.batchNo.size() > 0 && data.batchNo.size() < 100;
    }

    function isValidBandSawEntry(data) {
      return data.masterBatchNo is string && data.subBundleNo is string &&
             data.pcsCut is number && data.pcsCut > 0 &&
             data.weight is number && data.weight > 0 &&
             data.status in ['cut', 'centered', 'charging', 'hrm', 'hrm-hot-out', 'finished'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /batches/{batchId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidBatch(request.resource.data);
      allow delete: if isAdmin();
    }

    match /bandSawEntries/{entryId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() && isValidBandSawEntry(request.resource.data);
      allow delete: if isAdmin();
    }

    match /inspections/{inspectionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /productionReports/{reportId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }
  }
}
